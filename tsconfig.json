{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES2015",
    "moduleDetection": "force",
    "lib": ["ES2019", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": false,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
